+
+const sourcesByUrl = new Map<string, SocketSource>();
+const sourcesByPort = new Map<MessagePort, SocketSource>();
+
+function detachPort(port: MessagePort) {
+  const source = sourcesByPort.get(port);
+  if (!source) return;
