+const (
+	issueLiveSafetyRefreshInterval = 60 * time.Second
+	issueLivePingInterval          = 25 * time.Second
+	issueLiveWriteTimeout          = 10 * time.Second
+	issueLiveResumeTimeout         = 10 * time.Second
+	issueLiveReadLimit             = 1 << 22
