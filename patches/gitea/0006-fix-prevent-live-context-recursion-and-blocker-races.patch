 	glbRegex     = map[*regexp.Regexp]struct{}{}
 	glbPrefix    = map[netip.Prefix]struct{}{}
 	BlockConfigs = [2]*BlockerConfig{}
@@ -37,6 +39,9 @@ var (
 
 func ProcessBlockConfig() {
